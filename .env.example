# Public environment variables
NEXT_PUBLIC_CURRENCY=UGX
NEXT_PUBLIC_CLERK_FRONTEND_API=https://your-clerk-instance.clerk.accounts.dev
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Private environment variables
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key
CLERK_WEBHOOK_SECRET=whsec_your_clerk_webhook_secret
# Dev-only convenience. Keep false in staging/production.
ENABLE_SELF_ADMIN_BOOTSTRAP=false

MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net
MONGODB_DB_NAME=test

INNGEST_EVENT_KEY=your_inngest_event_key
INNGEST_SIGNING_KEY=your_inngest_signing_key

CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Cash on Delivery is the active checkout flow for now
EMAIL_PROVIDER=resend
EMAIL_ENABLED=false
EMAIL_DEBUG=true
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=KawilMart <notifications@yourdomain.com>
EMAIL_REPLY_TO=support@yourdomain.com
APP_BASE_URL=http://localhost:3000

SMS_ENABLED=false
SMS_PROVIDER=africastalking
AT_USERNAME=sandbox
AT_API_KEY=your_africastalking_api_key
AT_SMS_FROM=KawilMart
